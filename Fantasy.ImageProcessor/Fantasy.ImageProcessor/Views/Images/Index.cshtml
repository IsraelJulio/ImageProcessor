@{
    ViewData["Title"] = "Processador de Medalhas";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>Processador de Medalhas</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #111827;
            color: white;
            padding: 40px;
        }

        .card {
            max-width: 600px;
            margin: auto;
            background: #1f2937;
            padding: 30px;
            border-radius: 16px;
        }

        input, button {
            width: 100%;
            padding: 12px;
            margin-top: 16px;
        }

        button {
            background: #22c55e;
            color: white;
            border: none;
            cursor: pointer;
            font-weight: bold;
            border-radius: 8px;
        }

        .error {
            color: #f87171;
            margin-top: 16px;
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>Fantasy Image Processor</h1>
        <p>Selecione várias imagens para transformar em PNG 512x512 com fundo transparente.</p>

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

       <form action="/Images/Upload" method="post" enctype="multipart/form-data">
    <input type="file" name="files" multiple accept="image/png,image/jpeg,image/webp" />

    <button type="submit">
        Processar imagens
    </button>
</form>
    </div>
    <hr />

<h2>Comprimir imagens em lote</h2>

<form action="/Images/Compress" method="post" enctype="multipart/form-data">
    <input type="file" name="files" multiple accept="image/png,image/jpeg,image/webp" />

    <label>Largura máxima</label>
    <input type="number" name="maxWidth" value="1024" />

    <label>Qualidade</label>
    <input type="number" name="quality" value="75" min="1" max="100" />

    <label>Formato</label>
    <select name="format">
        <option value="webp">WebP - melhor compressão</option>
        <option value="jpg">JPG - mais compatível</option>
    </select>

    <button type="submit">
        Comprimir imagens
    </button>
</form>
</body>
</html>